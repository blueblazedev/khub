# ---- dispatch ---------------------------------------------------------------
main() {
  local cmd="${1:-help}"; if [ $# -gt 0 ]; then shift; fi
  case "$cmd" in
    init)            cmd_init "$@" ;;
    update)          cmd_update "$@" ;;
    upgrade|self-update) cmd_upgrade "$@" ;;
    doctor)          cmd_doctor "$@" ;;
    track)           cmd_track "$@" ;;
    metrics)         cmd_metrics "$@" ;;
    version|--version|-v) cmd_version "$@" ;;
    help|--help|-h)  usage ;;
    *)               printf 'unknown command: %s\n\n' "$cmd" >&2; usage >&2; exit 2 ;;
  esac
}
main "$@"
