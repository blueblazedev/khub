#!/usr/bin/env bash
set -euo pipefail
# =============================================================================
# khub — clone and keep a delivered knowledge-hub snapshot current, as a sibling
# of your code repos. Interface only: it talks to the private client repo using
# YOUR existing `gh` auth. Dependencies: git + gh (nothing else).
#
#   khub init [dir]   clone the hub as a sibling under dir (default: cwd)
#   khub update       fast-forward the hub clone (--dry-run previews; --reset)
#   khub upgrade      update the khub CLI itself (--check only reports)
#   khub doctor       diagnose the setup (--report emits a redacted diagnostic)
#   khub version      print the CLI version + the clone's latest snapshot
#
# The hub clone is PULL-ONLY: your work lives in your own code repos, which point
# back at ../knowledge-hub for context. Never commit into the clone.
# =============================================================================

KHUB_VERSION="0.2.0"
ORG="blueblazedev"
KHUB_REPO="${ORG}/khub"   # where the CLI itself lives (for self-upgrade)
CLIENT_REPO="${KHUB_CLIENT_REPO:-${ORG}/knowledge-hub-client}"
HUB_DIRNAME="knowledge-hub"
BOT_SUBJECT_PREFIX="publish: snapshot"
BOT_AUTHOR="knowledge-hub-bot"
STALE_DAYS="${KHUB_STALE_DAYS:-30}"

# ---- terminal style ---------------------------------------------------------
# 16-color + bold/dim only, and ONLY on an interactive TTY with NO_COLOR unset
# (piped/redirected/NO_COLOR runs therefore emit zero ANSI bytes).
c_reset=''; c_red=''; c_grn=''; c_ylw=''; c_blu=''; c_cyan=''; c_bold=''; c_dim=''
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  c_reset=$'\033[0m'; c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'
  c_blu=$'\033[34m'; c_cyan=$'\033[36m'; c_bold=$'\033[1m'; c_dim=$'\033[2m'
fi
# Glyphs: Unicode when the locale is UTF-8, else fixed-width ASCII so columns
# stay aligned. POSIX precedence: LC_ALL, then LC_CTYPE, then LANG.
_loc="${LC_ALL:-${LC_CTYPE:-${LANG:-}}}"
case "$_loc" in
  *UTF-8*|*utf-8*|*UTF8*|*utf8*)
    g_ok='✓'; g_warn='⚠'; g_bad='✗'; g_info='ℹ'; g_arrow='→'; g_pipe='│' ;;
  *)
    g_ok='OK'; g_warn='!!'; g_bad='XX'; g_info='i '; g_arrow='->'; g_pipe='|' ;;
esac

say()    { printf '%s\n' "$*"; }
# cyan '>' marker + bold title
title()  { printf '%s%s>%s %s%s%s\n' "$c_cyan" "$c_bold" "$c_reset" "$c_bold" "$*" "$c_reset"; }
# check rows: colored glyph carries the status; the message stays plain
ok()     { printf '  %s%s%s %s\n' "$c_grn" "$g_ok"   "$c_reset" "$*"; }
warn()   { printf '  %s%s%s %s\n' "$c_ylw" "$g_warn" "$c_reset" "$*"; }
bad()    { printf '  %s%s%s %s\n' "$c_red" "$g_bad"  "$c_reset" "$*"; }
info()   { printf '  %s%s%s %s\n' "$c_blu" "$g_info" "$c_reset" "$*"; }
# dim '→' fix-hint continuation and dim detail line
hint()   { printf '  %s%s %s%s\n' "$c_dim" "$g_arrow" "$*" "$c_reset"; }
detail() { printf '  %s%s%s\n' "$c_dim" "$*" "$c_reset"; }
# doctor-only frame: a dim │ guide down the left, bold-cyan section headers
frame_section() { printf '%s%s%s %s%s%s\n' "$c_dim" "$g_pipe" "$c_reset" "$c_bold$c_cyan" "$*" "$c_reset"; }
fok()    { printf '%s%s%s %s%s%s %s\n' "$c_dim" "$g_pipe" "$c_reset" "$c_grn" "$g_ok"   "$c_reset" "$*"; }
fwarn()  { printf '%s%s%s %s%s%s %s\n' "$c_dim" "$g_pipe" "$c_reset" "$c_ylw" "$g_warn" "$c_reset" "$*"; }
fbad()   { printf '%s%s%s %s%s%s %s\n' "$c_dim" "$g_pipe" "$c_reset" "$c_red" "$g_bad"  "$c_reset" "$*"; }
fhint()  { printf '%s%s%s   %s%s %s%s\n' "$c_dim" "$g_pipe" "$c_reset" "$c_dim" "$g_arrow" "$*" "$c_reset"; }
# die keeps a red 'error:'; the fix hint becomes a dim '→'
die()    {
  printf '%serror:%s %s\n' "$c_red" "$c_reset" "$1" >&2
  if [ $# -ge 2 ]; then printf '  %s%s %s%s\n' "$c_dim" "$g_arrow" "$2" "$c_reset" >&2; fi
  exit 1
}
# Display a path with $HOME collapsed to ~ and a long middle elided.
tilde() {
  local p="$1"
  case "$p" in "$HOME"*) p="~${p#"$HOME"}" ;; esac
  if [ "${#p}" -gt 48 ]; then printf '%s…%s' "${p:0:24}" "${p: -21}"; else printf '%s' "$p"; fi
}

# ---- individual checks (reused by doctor AND init preflight) -----------------
have_git()   { command -v git >/dev/null 2>&1; }
have_gh()    { command -v gh  >/dev/null 2>&1; }
gh_authed()  { gh auth status >/dev/null 2>&1; }
api_access() { gh repo view "$CLIENT_REPO" >/dev/null 2>&1; }
# API access (a REST read) does NOT prove clone access — the git transport uses a
# separate credential path. Probe it directly with the gh-provided git creds.
git_transport_access() {
  local url; url="$(gh_clone_url)"
  GIT_TERMINAL_PROMPT=0 git ls-remote "$url" >/dev/null 2>&1
}
gh_clone_url() {
  # honour gh's configured protocol; default to https which gh can credential.
  printf 'https://github.com/%s.git' "$CLIENT_REPO"
}

# ---- hub-clone location + snapshot inspection -------------------------------
# Find the knowledge-hub clone: explicit --path, else cwd, else a sibling, else
# parent (when run from inside a code repo that sits beside the hub).
find_hub_dir() {
  local p="$1"
  if [ -n "$p" ]; then if [ -d "$p" ]; then printf '%s' "$p"; return 0; else return 1; fi; fi
  if [ -f "./AGENTS.md" ] && [ -d "./.knowledge" ]; then printf '%s' "." && return 0; fi
  # A knowledge-hub/ clone counts even before its first snapshot lands (empty repo
  # → no .knowledge yet). Accept a git clone by its .git so a fresh `khub init`
  # is diagnosed here — NOT silently skipped in favour of an unrelated sibling.
  # ./knowledge-hub is checked before ../knowledge-hub so a local clone always wins.
  if [ -d "./$HUB_DIRNAME/.knowledge" ] || [ -e "./$HUB_DIRNAME/.git" ]; then printf '%s' "./$HUB_DIRNAME" && return 0; fi
  if [ -d "../$HUB_DIRNAME/.knowledge" ] || [ -e "../$HUB_DIRNAME/.git" ]; then printf '%s' "../$HUB_DIRNAME" && return 0; fi
  return 1
}
is_git_repo()      { git -C "$1" rev-parse --git-dir >/dev/null 2>&1; }
has_commits()      { git -C "$1" rev-parse HEAD >/dev/null 2>&1; }   # false on a just-cloned empty repo
latest_subject()   { git -C "$1" log -1 --pretty=%s 2>/dev/null; }
latest_author()    { git -C "$1" log -1 --pretty=%an 2>/dev/null; }
latest_short_sha() { git -C "$1" log -1 --pretty=%h 2>/dev/null; }
latest_iso_date()  { git -C "$1" log -1 --pretty=%cI 2>/dev/null; }
# A genuine snapshot is a bot commit BY SUBJECT AND AUTHOR — subject alone is
# visible in the client's own log and trivially spoofable by anyone who can write.
is_bot_snapshot() {
  case "$(latest_subject "$1")" in "$BOT_SUBJECT_PREFIX"*) ;; *) return 1;; esac
  [ "$(latest_author "$1")" = "$BOT_AUTHOR" ]
}
# whole-day age of the latest commit; empty if undeterminable. Use git's own
# committer epoch (%ct) — no date-string parsing (BSD vs GNU `date` disagree on
# tz offsets, which silently broke this on macOS).
snapshot_age_days() {
  local ct now; ct="$(git -C "$1" log -1 --pretty=%ct 2>/dev/null)"; [ -n "$ct" ] || return 1
  now="$(date +%s)"
  printf '%s' "$(( (now - ct) / 86400 ))"
}
has_local_commits() {  # commits on HEAD not on the upstream = someone wrote to the clone
  git -C "$1" rev-parse '@{u}' >/dev/null 2>&1 || return 1
  [ -n "$(git -C "$1" rev-list '@{u}..HEAD' 2>/dev/null)" ]
}

# ---- sha256 (portable) ------------------------------------------------------
# Compute a file's sha256 with whichever tool exists (both preinstalled on
# macOS/Linux). String-compared later — avoids `-c` flag divergence.
sha256_of() {
  if command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'
  else return 1; fi
}

# ---- upgrade-nudge cache ----------------------------------------------------
# Cache the latest-release probe so version/doctor can mention a newer CLI
# without a network round-trip each time. Positive entries live 7d; a failed
# probe writes a negative stamp that lives 1d, so offline/proxied users retry at
# most once a day instead of stalling 2s on every command.
NUDGE_TTL_OK=604800
NUDGE_TTL_NEG=86400
cache_dir()  { printf '%s/khub' "${XDG_CACHE_HOME:-$HOME/.cache}"; }
cache_file() { printf '%s/khub/latest-release' "${XDG_CACHE_HOME:-$HOME/.cache}"; }
# A release tag we will trust enough to cache and later print near a terminal.
# Anchored allowlist (^v[0-9][0-9A-Za-z.+-]*$) kills ANSI/OSC injection via a
# crafted tag_name (the API field is attacker-influenced if a release is forged).
valid_tag() {
  case "$1" in v[0-9]*) ;; *) return 1 ;; esac
  case "$1" in *[!0-9A-Za-z.+-]*) return 1 ;; esac
  return 0
}
# Probe the latest tag. MUST NOT abort under set -e (fully guarded) and MUST be
# time-boxed (curl -m 2). Writes a positive or negative cache stamp.
nudge_probe() {
  local tag
  mkdir -p "$(cache_dir)" 2>/dev/null || return 0
  tag="$(curl -m 2 -sfL "https://api.github.com/repos/${KHUB_REPO}/releases/latest" 2>/dev/null \
    | sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 || true)"
  if [ -n "$tag" ] && valid_tag "$tag"; then
    printf '%s %s\n' "$tag" "$(date +%s)" > "$(cache_file)" 2>/dev/null || true
  else
    printf -- '- %s\n' "$(date +%s)" > "$(cache_file)" 2>/dev/null || true
  fi
  return 0
}
# Read the cache. Prints "<tag>" (fresh positive), "-" (fresh negative — a probe
# failed recently, stay quiet), or nothing (stale/missing → caller should probe).
# Always returns 0 so it is safe on the right of an assignment under set -e.
nudge_cache_read() {
  local f line tag stamp now age
  f="$(cache_file)"
  if [ ! -f "$f" ]; then return 0; fi
  line="$(head -1 "$f" 2>/dev/null || true)"
  if [ -z "$line" ]; then return 0; fi
  tag="${line%% *}"; stamp="${line##* }"
  case "$stamp" in ''|*[!0-9]*) return 0 ;; esac
  # Force base-10: a leading-zero stamp (e.g. 0888) is an invalid OCTAL literal in
  # $(( )) and would abort under set -e — an all-digits guard alone is not enough.
  now="$(date +%s)"; age=$(( now - 10#${stamp} ))
  if [ "$tag" = "-" ]; then
    if [ "$age" -lt "$NUDGE_TTL_NEG" ]; then printf -- '-'; fi
    return 0
  fi
  if [ "$age" -ge "$NUDGE_TTL_OK" ]; then return 0; fi
  if ! valid_tag "$tag"; then return 0; fi
  printf '%s' "$tag"
  return 0
}
# Emit the upgrade nudge (one ℹ line) when a newer release is known. Uses a fresh
# cache as-is; probes once when stale/missing. `update` never calls this.
nudge_line() {
  local tag
  tag="$(nudge_cache_read)"
  if [ -z "$tag" ]; then nudge_probe; tag="$(nudge_cache_read)"; fi
  if [ -z "$tag" ] || [ "$tag" = "-" ]; then return 0; fi
  if [ "$tag" = "v${KHUB_VERSION}" ]; then return 0; fi
  info "khub ${tag} is available — run 'khub upgrade'"
}

# ---- doctor --report --------------------------------------------------------
# Redact a block for safe pasting: $HOME → ~ and the gh login (if resolvable) →
# <user> everywhere (catches a username embedded in a non-HOME path). stdin→stdout.
redact() {
  local login
  login="$(gh api user -q .login 2>/dev/null || true)"
  if [ -n "$login" ]; then
    sed -e "s#${HOME}#~#g" -e "s#${login}#<user>#g"
  else
    sed -e "s#${HOME}#~#g"
  fi
}
# Emit a fenced, redacted diagnostic block. Printed even when checks FAIL (that
# is its use case). Args: <hub_path_or_empty> <fail_count>.
doctor_report() {
  local hub="$1" fails="$2"
  local os git_v gh_v auth repo_disp snap botauth ffclean age
  os="$(uname -sm 2>/dev/null || echo unknown)"
  git_v="$(git --version 2>/dev/null || echo 'not installed')"
  gh_v="$(gh --version 2>/dev/null | head -1 || echo 'not installed')"
  if have_gh && gh_authed; then
    auth="authenticated (host: $(gh auth status 2>&1 | sed -n 's/.*Logged in to \([^ ]*\).*/\1/p' | head -1 || echo github.com))"
  else
    auth="not authenticated"
  fi
  if [ -n "${KHUB_CLIENT_REPO:-}" ]; then repo_disp="custom (env-set)"; else repo_disp="default"; fi
  snap="none"; botauth="n/a"; ffclean="n/a"; age=""
  if [ -n "$hub" ] && has_commits "$hub"; then
    snap="$(latest_short_sha "$hub")  $(latest_iso_date "$hub")"
    if age="$(snapshot_age_days "$hub")"; then :; else age=""; fi
    if is_bot_snapshot "$hub"; then botauth="yes"; else botauth="no"; fi
    if has_local_commits "$hub"; then ffclean="no"; else ffclean="yes"; fi
  fi
  {
    printf '```\n'
    printf 'khub %s\n' "$KHUB_VERSION"
    printf 'os: %s\n' "$os"
    printf 'bash: %s\n' "${BASH_VERSION:-unknown}"
    printf 'git: %s\n' "$git_v"
    printf 'gh: %s\n' "$gh_v"
    printf 'gh auth: %s\n' "$auth"
    printf 'client repo: %s\n' "$repo_disp"
    if [ -n "$hub" ]; then printf 'hub path: %s\n' "$hub"; else printf 'hub path: not found\n'; fi
    printf 'snapshot: %s\n' "$snap"
    if [ -n "$age" ]; then printf 'snapshot age: %sd\n' "$age"; fi
    printf 'bot-authored: %s\n' "$botauth"
    printf 'ff-clean: %s\n' "$ffclean"
    printf 'checks failed: %s\n' "$fails"
    printf '```\n'
  } | redact
}

# ---- verbs ------------------------------------------------------------------
cmd_version() {
  printf '%skhub %s%s\n' "$c_bold" "$KHUB_VERSION" "$c_reset"
  local hub; if hub="$(find_hub_dir "${1:-}")" && is_git_repo "$hub"; then
    detail "hub clone: $(tilde "$hub")"
    if ! has_commits "$hub"; then
      detail "latest snapshot: none yet (empty clone — no snapshot published)"
    elif is_bot_snapshot "$hub"; then
      detail "latest snapshot: $(latest_short_sha "$hub")  $(latest_iso_date "$hub")"
    else
      detail "latest commit: $(latest_short_sha "$hub") (not a published snapshot)"
    fi
  else
    detail "hub clone: not found (run 'khub init')"
  fi
  nudge_line
}

preflight() {
  have_git || die "git is not installed" "install git, then re-run"
  have_gh  || die "the GitHub CLI 'gh' is not installed" "https://cli.github.com then 'gh auth login'"
  gh_authed || die "not logged in to GitHub" "run 'gh auth login'"
  api_access || die "no access to ${CLIENT_REPO}" "ask the owner to add you as a collaborator, then re-run"
  git_transport_access || die "gh is authed but git cannot clone ${CLIENT_REPO}" "run 'gh auth setup-git' to wire git to your gh credentials"
}

cmd_init() {
  local dir="${1:-.}"
  [ -d "$dir" ] || die "target directory does not exist: $dir"
  local target="${dir%/}/${HUB_DIRNAME}"
  if [ -e "$target" ]; then
    if is_git_repo "$target"; then
      die "a hub clone already exists at $target" "run 'khub update' to refresh it"
    else
      die "path already exists and is not a hub clone: $target"
    fi
  fi
  title "khub init"
  say "Preflight…"; preflight; ok "git, gh auth, API + clone access all good"
  say "Cloning ${CLIENT_REPO} → $(tilde "$target")"
  gh repo clone "$CLIENT_REPO" "$target" >/dev/null 2>&1 || die "clone failed" "re-run 'khub doctor' to diagnose"
  say ""
  if ! has_commits "$target"; then
    warn "the client repo has no published snapshot yet — the clone is empty for now."
    hint "run 'khub update' once the first snapshot is published; nothing else to do."
    return 0
  fi
  ok "the hub is at $(tilde "$target") (pull-only — keep it current with 'khub update')."
  say "Next steps:"
  hint "point a code repo at the hub:  (cd \"$target\" && scripts/bootstrap-sibling.sh <your-code-repo-git-url>)"
  hint "read the entry point:          ${target}/AGENTS.md"
  hint "health check any time:         khub doctor"
}

cmd_update() {
  local path="" reset=0 dryrun=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --path) path="${2:-}"; shift 2 ;;
      --reset) reset=1; shift ;;
      --dry-run) dryrun=1; shift ;;
      *) die "unknown option for update: $1" "see 'khub help'";;
    esac
  done
  if [ "$dryrun" = "1" ] && [ "$reset" = "1" ]; then die "--dry-run and --reset are mutually exclusive" "pick one"; fi
  local hub; hub="$(find_hub_dir "$path")" || die "no ${HUB_DIRNAME}/ clone found" "run 'khub init' first, or pass --path DIR"
  is_git_repo "$hub" || die "$hub is not a git clone" "re-clone with 'khub init'"

  # --- dry-run: fetch, report what WOULD change, never move HEAD ---
  if [ "$dryrun" = "1" ]; then
    title "khub update --dry-run — $(tilde "$hub")"
    git -C "$hub" fetch --quiet origin || die "fetch failed" "check network + 'khub doctor'"
    if ! has_commits "$hub"; then
      if git -C "$hub" rev-parse '@{u}' >/dev/null 2>&1; then
        say "a first snapshot is available — run 'khub update' to pull it."
      else
        say "no snapshot published yet — nothing to preview."
      fi
      return 0
    fi
    if git -C "$hub" merge-base --is-ancestor HEAD '@{u}' 2>/dev/null; then
      if [ -n "$(git -C "$hub" rev-list 'HEAD..@{u}' 2>/dev/null)" ]; then
        say "incoming snapshots (not yet applied):"
        git -C "$hub" log --oneline --no-decorate 'HEAD..@{u}' | while IFS= read -r l; do detail "$l"; done
        detail "$(git -C "$hub" diff --stat 'HEAD..@{u}' | tail -1)"
        hint "run 'khub update' to apply"
      else
        ok "up to date — nothing to apply."
      fi
    else
      warn "local history has diverged — cannot fast-forward; run 'khub doctor'."
    fi
    return 0
  fi

  title "khub update — $(tilde "$hub")"
  git -C "$hub" fetch --quiet origin || die "fetch failed" "check network + 'khub doctor'"

  # Empty clone (client repo had no snapshot when it was cloned): pull the first
  # snapshot if one now exists, otherwise there is simply nothing to update yet.
  if ! has_commits "$hub"; then
    if git -C "$hub" rev-parse '@{u}' >/dev/null 2>&1; then
      git -C "$hub" merge --ff-only --quiet '@{u}' || die "could not pull the first snapshot" "run 'khub doctor'"
      ok "pulled the first snapshot: $(latest_short_sha "$hub")  ($(latest_iso_date "$hub"))"
    else
      say "no snapshot published yet — nothing to update (try again after the first publish)."
    fi
    return 0
  fi

  # Capture HEAD before the merge so we can show exactly what came in.
  local old; old="$(git -C "$hub" rev-parse HEAD)"

  if [ "$reset" = "1" ]; then
    printf '%s%s%s This DISCARDS all local changes in %s and matches the published snapshot. Continue? [y/N] ' "$c_ylw" "$g_warn" "$c_reset" "$hub"
    read -r ans; case "$ans" in [yY]*) : ;; *) die "aborted";; esac
    git -C "$hub" reset --hard '@{u}' --quiet && git -C "$hub" clean -fd >/dev/null 2>&1
    ok "reset to the latest snapshot."
  elif git -C "$hub" merge-base --is-ancestor HEAD '@{u}' 2>/dev/null; then
    git -C "$hub" merge --ff-only --quiet '@{u}' || die "fast-forward failed unexpectedly" "run 'khub doctor'"
  else
    # Cannot fast-forward. Counting divergent commits cannot tell "I wrote to the
    # clone" apart from "upstream was rewritten" — after a leak-incident force-push
    # the orphaned bot snapshots ARE divergent commits. The AUTHOR is the tell:
    # any non-bot commit = genuine local work; all-bot divergence = upstream rewrite.
    local nonbot
    nonbot="$(git -C "$hub" log '@{u}..HEAD' --format='%an' 2>/dev/null | grep -vcx "$BOT_AUTHOR" || true)"
    if [ "${nonbot:-0}" -gt 0 ]; then
      die "this clone has local commits — it is pull-only" \
        "move your work into your own code repos, then 'khub update --reset' (discards local changes, confirms first)"
    else
      die "upstream history was rewritten (non-fast-forward)" \
        "leak-incident re-clone path: delete '$hub' and 'khub init' again — do NOT --reset (that keeps the purged content in local git objects)"
    fi
  fi

  # What's-new: if HEAD moved (fast-forward only), show the incoming snapshot
  # subjects (capped) + the diffstat summary line.
  local new; new="$(git -C "$hub" rev-parse HEAD 2>/dev/null || true)"
  if [ "$reset" != "1" ] && [ -n "$old" ] && [ -n "$new" ] && [ "$old" != "$new" ]; then
    local n; n="$(git -C "$hub" rev-list --count "${old}..${new}" 2>/dev/null || echo 0)"
    say "what's new (${n} snapshot(s)):"
    # Cap with git itself (-n 20), NOT `| head`: piping to head SIGPIPEs git on a
    # large catch-up, and under pipefail+set -e that would abort update AFTER the
    # merge already landed, skipping the tamper/staleness checks below.
    git -C "$hub" log -n 20 --oneline --no-decorate "${old}..${new}" 2>/dev/null | while IFS= read -r l; do detail "$l"; done
    if [ "$n" -gt 20 ]; then detail "… and $((n - 20)) more"; fi
    detail "$(git -C "$hub" diff --stat "${old}..${new}" 2>/dev/null | tail -1)"
  fi

  # post-update sanity: is this a genuine, fresh, untampered snapshot?
  if [ ! -f "$hub/AGENTS.md" ] || [ ! -f "$hub/.knowledge/README.md" ]; then
    warn "expected hub files missing — the clone may be corrupt (re-init)"
  fi
  if is_bot_snapshot "$hub"; then
    ok "at snapshot $(latest_short_sha "$hub")  ($(latest_iso_date "$hub"))"
  else
    warn "latest commit is not a published snapshot (subject: '$(latest_subject "$hub")') — possible tampering"
  fi
  local age; if age="$(snapshot_age_days "$hub")" && [ "$age" -gt "$STALE_DAYS" ]; then
    warn "snapshot is ${age} days old (> ${STALE_DAYS}) — the publisher may be stuck; ask the owner"
  fi
}

cmd_doctor() {
  local path="" report=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --path) path="${2:-}"; shift 2 ;;
      --report) report=1; shift ;;
      *) die "unknown option for doctor: $1" "see 'khub help'";;
    esac
  done
  title "khub doctor — ${CLIENT_REPO}"
  local fails=0 hub=""

  frame_section "SYSTEM"
  if have_git; then fok "git installed"; else fbad "git not installed"; fhint "install git"; fails=$((fails+1)); fi
  if have_gh; then fok "gh installed"; else fbad "gh not installed"; fhint "https://cli.github.com"; fails=$((fails+1)); fi

  frame_section "ACCESS"
  if have_gh && gh_authed; then fok "gh authenticated"; else fbad "gh not authenticated"; fhint "run 'gh auth login'"; fails=$((fails+1)); fi
  if have_gh && gh_authed && api_access; then fok "API access to ${CLIENT_REPO}"; else fbad "no access to ${CLIENT_REPO}"; fhint "ask the owner to add you as a collaborator"; fails=$((fails+1)); fi
  if have_gh && gh_authed && git_transport_access; then fok "git clone access (transport)"; else fbad "git cannot clone"; fhint "run 'gh auth setup-git'"; fails=$((fails+1)); fi

  frame_section "HUB CLONE"
  if hub="$(find_hub_dir "$path")"; then
    fok "hub clone found at $(tilde "$hub")"
    if ! is_git_repo "$hub"; then
      fbad "$(tilde "$hub") exists but is not a git clone"; fhint "re-init"; fails=$((fails+1)); hub=""
    elif ! has_commits "$hub"; then
      fwarn "clone is empty — no snapshot published yet (run 'khub update' after the first publish)"
    else
      if is_bot_snapshot "$hub"; then fok "latest commit is a published snapshot ($(latest_short_sha "$hub"))"; else fbad "latest commit is NOT a published snapshot"; fhint "possible tampering — re-init"; fails=$((fails+1)); fi
      if has_local_commits "$hub"; then fbad "clone has local commits — it is pull-only"; fhint "move work to your own repos"; fails=$((fails+1)); else fok "clone is fast-forward-clean (no local commits)"; fi
      local age; if age="$(snapshot_age_days "$hub")"; then
        if [ "$age" -gt "$STALE_DAYS" ]; then fwarn "snapshot is ${age}d old (> ${STALE_DAYS}) — ask the owner if publishing is stuck"; else fok "snapshot is fresh (${age}d old)"; fi
      fi
    fi
  else
    # The BOOTSTRAP #1 footgun: a code repo whose CLAUDE.md points at a hub that
    # is not checked out beside it.
    if [ -f "./CLAUDE.md" ] && grep -q "knowledge-hub" ./CLAUDE.md 2>/dev/null; then
      fbad "this repo points at ../${HUB_DIRNAME} but no hub clone is beside it"; fhint "run: khub init .."
    else
      fbad "no ${HUB_DIRNAME}/ clone found"; fhint "run 'khub init'"
    fi
    fails=$((fails+1)); hub=""
  fi

  # A newer CLI is worth surfacing here, before the verdict.
  nudge_line
  # The report prints BEFORE the summary and EVEN WHEN checks failed — that is
  # exactly when a copy-paste diagnostic is wanted. Exit code below is preserved.
  if [ "$report" = "1" ]; then say ""; doctor_report "$hub" "$fails"; fi

  say ""
  if [ "$fails" -eq 0 ]; then
    printf '%s%s%s all checks passed\n' "$c_grn" "$g_ok" "$c_reset"
  else
    printf '%s%s%s %s check(s) failed — see fixes above\n' "$c_red" "$g_bad" "$c_reset" "$fails"
    return 1
  fi
}

cmd_upgrade() {
  local check=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --check) check=1; shift ;;
      *) die "unknown option for upgrade: $1" "see 'khub help'";;
    esac
  done
  command -v curl >/dev/null 2>&1 || die "curl is required to upgrade" "install curl, then re-run"
  local self bindir tag
  self="$(command -v khub 2>/dev/null || true)"; [ -n "$self" ] || self="$0"
  bindir="$(dirname "$self")"
  tag="$(curl -m 2 -sfL "https://api.github.com/repos/${KHUB_REPO}/releases/latest" 2>/dev/null \
    | sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 || true)"
  [ -n "$tag" ] || die "could not resolve the latest khub release" "check your network"
  valid_tag "$tag" || die "the latest release tag looks malformed — refusing to act on it" "reinstall via the README one-liner"
  # Refresh the nudge cache from this live probe: keeps version/doctor honest and
  # prevents nudging "backward" right after a direct upgrade.
  if mkdir -p "$(cache_dir)" 2>/dev/null; then printf '%s %s\n' "$tag" "$(date +%s)" > "$(cache_file)" 2>/dev/null || true; fi

  if [ "$check" = "1" ]; then
    if [ "$tag" = "v${KHUB_VERSION}" ]; then
      ok "khub is up to date (${tag})."
    else
      title "khub upgrade --check"
      say "current: v${KHUB_VERSION}"
      say "latest:  ${tag}"
      hint "run 'khub upgrade' to update"
    fi
    return 0
  fi

  if [ "$tag" = "v${KHUB_VERSION}" ]; then ok "already on the latest khub (${tag})."; return 0; fi

  title "Upgrading khub (v${KHUB_VERSION} → ${tag}) in $(tilde "$bindir")"
  # Verified upgrade: download install.sh AND SHA256SUMS for this tag, verify the
  # installer BEFORE executing it (no more blind curl|bash). The installer then
  # re-verifies the binary itself.
  local sh_tmp sums_tmp expected actual
  # tmpd is deliberately NOT `local`: the EXIT trap fires in the global scope
  # after this function returns, so a local would be out of scope there and
  # set -u would abort the trap with "tmpd: unbound variable".
  tmpd="$(mktemp -d)" || die "could not create a temp directory"
  trap 'rm -rf "$tmpd"' EXIT
  sh_tmp="$tmpd/install.sh"; sums_tmp="$tmpd/SHA256SUMS"
  curl -sfL "https://github.com/${KHUB_REPO}/releases/download/${tag}/install.sh" -o "$sh_tmp" \
    || die "could not download the installer for ${tag}" "retry, or reinstall via the README one-liner"
  curl -sfL "https://github.com/${KHUB_REPO}/releases/download/${tag}/SHA256SUMS" -o "$sums_tmp" \
    || die "no checksums published for ${tag} — refusing to run an unverified installer" "retry later, or reinstall via the README one-liner"
  expected="$(awk '$2 == "install.sh" { print $1 }' "$sums_tmp")"
  [ -n "$expected" ] || die "checksums for ${tag} have no install.sh entry" "reinstall via the README one-liner"
  actual="$(sha256_of "$sh_tmp")" || die "no sha256 tool (shasum/sha256sum) available — cannot verify"
  [ "$actual" = "$expected" ] || die "installer checksum mismatch for ${tag} — refusing to run it" "retry later, or reinstall via the README one-liner"
  KHUB_INSTALL_VERSION="$tag" KHUB_BIN_DIR="$bindir" bash "$sh_tmp" \
    || die "upgrade failed" "re-run the install one-liner from the ${KHUB_REPO} README"
}

# ---- track (opt-in session telemetry) ---------------------------------------
# khub distils a python3 dual-hook (SessionStart + SessionEnd) and NON-DESTRUCTIVELY
# registers it in ~/.claude/settings.json at user scope, so it can measure "ways of
# working" from real Claude Code sessions. LOCAL-FIRST, OFF by default, opt-in only.
# All JSON work is delegated to lib/telemetry/settings_merge.py — this bash never
# parses JSON. Every command-substitution below is guarded so `set -e` cannot abort
# mid-mutation and leave a half-applied state.
TELEMETRY_SCHEMA_VERSION=1

# khub's own files, relative to the real script (dev/checkout layout). A single-file
# install has no lib/ beside it — embedding lib/ as a release step is deferred; until
# then telemetry runs from a full checkout or with KHUB_LIB_DIR set. Fails closed with
# an actionable message when the helper is absent.
khub_lib_dir() {
  if [ -n "${KHUB_LIB_DIR:-}" ]; then printf '%s' "$KHUB_LIB_DIR"; return 0; fi
  local self dir
  self="$(command -v khub 2>/dev/null || true)"; [ -n "$self" ] || self="$0"
  if [ -L "$self" ]; then self="$(readlink "$self" 2>/dev/null || printf '%s' "$self")"; fi
  dir="$(cd "$(dirname "$self")" >/dev/null 2>&1 && pwd)" || dir="."
  printf '%s/lib' "$dir"
}
tel_config_file() { printf '%s/khub/telemetry.conf' "${XDG_CONFIG_HOME:-$HOME/.config}"; }
tel_task_file()   { printf '%s/khub/telemetry-task' "${XDG_CONFIG_HOME:-$HOME/.config}"; }
tel_hook_dir()    { printf '%s/khub-telemetry' "${XDG_DATA_HOME:-$HOME/.local/share}"; }
tel_hook_file()   { printf '%s/capture_hook.py' "$(tel_hook_dir)"; }
tel_state_dir()   { printf '%s/khub-telemetry' "${XDG_STATE_HOME:-$HOME/.local/state}"; }
# Always exits 0 (prints the path, or nothing) so it is safe on an assignment RHS.
tel_python3()     { command -v python3 2>/dev/null || true; }
tel_settings_path() {  # <user|project>
  if [ "$1" = "project" ]; then printf '%s/.claude/settings.json' "$PWD"
  else printf '%s/.claude/settings.json' "$HOME"; fi
}
# The registered command: ABSOLUTE interpreter + hook path (pinned at enable time so
# a later PATH/venv change cannot 127 a session), guarded `|| exit 0` (fail-open).
tel_hook_command() { printf "'%s' '%s' || exit 0" "$1" "$2"; }

# Enterprise-managed settings OVERRIDE user settings, so a user-scope merge would be
# silently overridden — detect the platform managed path and steer to project scope.
tel_managed_present() {
  case "$(uname -s 2>/dev/null || true)" in
    Darwin) [ -f "/Library/Application Support/ClaudeCode/managed-settings.json" ] ;;
    *)      [ -f "/etc/claude-code/managed-settings.json" ] ;;
  esac
}

# Read one key=value from the config; prints the value (possibly empty), returns 1 if
# the key/file is absent so callers can `|| true` and default.
tel_config_get() {  # <key>
  local cfg line; cfg="$(tel_config_file)"
  [ -f "$cfg" ] || return 1
  line="$(grep -m1 "^$1=" "$cfg" 2>/dev/null)" || return 1
  printf '%s' "${line#*=}"
}

# Run the JSON merge helper. Returns the helper's exit code (0 ok, 3 malformed,
# 4 not-writable, 5 raced). Dies only if the helper file itself is missing.
tel_merge() {  # <subcommand> <settings_path> [args...]
  local lib py; lib="$(khub_lib_dir)/telemetry/settings_merge.py"
  [ -f "$lib" ] || die "telemetry helper not found: $(tilde "$lib")" "run telemetry from a full khub checkout or set KHUB_LIB_DIR"
  py="$(tel_python3)"; [ -n "$py" ] || die "python3 is required for khub telemetry" "install python3, then re-run"
  "$py" "$lib" "$@"
}

# Install (or reinstall) the hook file 0500 under a 0700 dir; print its sha256.
# Returns 1 (message on stderr) on any failure so the caller can roll back.
tel_install_hook() {
  local src dir dst sha
  src="$(khub_lib_dir)/telemetry/capture_hook.py"
  [ -f "$src" ] || { printf 'telemetry hook source not found: %s\n' "$src" >&2; return 1; }
  dir="$(tel_hook_dir)"; dst="$(tel_hook_file)"
  mkdir -p "$dir" 2>/dev/null || { printf 'cannot create hook dir: %s\n' "$dir" >&2; return 1; }
  chmod 700 "$dir" 2>/dev/null || true
  rm -f "$dst" 2>/dev/null || true          # 0500 dest is unwritable; replace it
  cp "$src" "$dst" || { printf 'cannot install hook file: %s\n' "$dst" >&2; return 1; }
  chmod 500 "$dst" 2>/dev/null || true
  sha="$(sha256_of "$dst")" || { printf 'no sha256 tool (shasum/sha256sum) available\n' >&2; return 1; }
  printf '%s' "$sha"
}

# Write the config atomically (temp+rename, 0600). Values are paths/enums/hex — no
# newlines — so printf is safe and no JSON is constructed in bash.
tel_write_config() {  # <enabled> <sha> <python3> <scope> <settings_path>
  local cfg dir tmp; cfg="$(tel_config_file)"; dir="$(dirname "$cfg")"
  mkdir -p "$dir" 2>/dev/null || die "cannot create config dir: $(tilde "$dir")"
  tmp="$(mktemp "$dir/.telemetry.XXXXXX")" || die "cannot write telemetry config"
  {
    printf 'enabled=%s\n' "$1"
    printf 'schema_version=%s\n' "$TELEMETRY_SCHEMA_VERSION"
    printf 'cohort=\n'
    printf 'hook_sha256=%s\n' "$2"
    printf 'python3=%s\n' "$3"
    printf 'scope=%s\n' "$4"
    printf 'settings_path=%s\n' "$5"
  } > "$tmp" || { rm -f "$tmp"; die "cannot write telemetry config"; }
  chmod 600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$cfg" || { rm -f "$tmp"; die "cannot finalize telemetry config"; }
}

track_notice() {
  title "khub track enable — session telemetry (opt-in)"
  say "Records LOCAL-ONLY, per-session process metrics from your Claude Code sessions"
  say "(prompt/turn counts, tool usage, token totals, timings) to compare ways of working."
  hint "captured to your machine only — nothing is sent anywhere"
  hint "registers a hook in your Claude Code settings.json (backed up first)"
  hint "disable + clean any time:  khub track disable"
  say ""
}

track_enable() {
  local scope="user"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) scope="project"; shift ;;
      *) die "unknown option for track enable: $1" "try: khub track enable [--project]" ;;
    esac
  done

  track_notice

  # 1) python3 is REQUIRED — hard-fail, change nothing (no "enabled but capturing
  #    nothing" half-state).
  local py; py="$(tel_python3)"
  [ -n "$py" ] || die "python3 is required for khub telemetry but was not found" \
    "install python3, then re-run 'khub track enable' — nothing was changed"

  # 2) managed user settings would silently override the merge — steer to project.
  if [ "$scope" = "user" ] && tel_managed_present; then
    die "this machine has enterprise-managed Claude Code settings (user scope would be overridden)" \
      "run 'khub track enable --project' to install into this repo's .claude/settings.json instead"
  fi

  local settings; settings="$(tel_settings_path "$scope")"

  # 3) install + fingerprint the hook (fallible work BEFORE any enabled flag).
  local sha; sha="$(tel_install_hook)" || die "could not install the telemetry hook" "see the message above — nothing was enabled"

  # 4) register in settings.json; roll the hook back on any failure.
  local cmd rc=0; cmd="$(tel_hook_command "$py" "$(tel_hook_file)")"
  tel_merge enable "$settings" --command "$cmd" || rc=$?
  if [ "$rc" -ne 0 ]; then
    rm -f "$(tel_hook_file)" 2>/dev/null || true
    case "$rc" in
      4) die "cannot write $(tilde "$settings")" "try 'khub track enable --project', or fix its permissions" ;;
      3) die "$(tilde "$settings") is not valid JSON — refusing to touch it" "fix or move it, then re-run" ;;
      5) die "$(tilde "$settings") changed while enabling — retry" "run 'khub track enable' again" ;;
      *) die "could not register the telemetry hook (code $rc)" "run 'khub track status' to inspect" ;;
    esac
  fi

  # 5) only now record the enabled flag — every fallible step above already passed.
  tel_write_config 1 "$sha" "$py" "$scope" "$settings"

  ok "telemetry enabled (${scope} scope)"
  detail "settings: $(tilde "$settings")  (a backup was kept alongside)"
  detail "hook:     $(tilde "$(tel_hook_file)")"
  hint "check it:  khub track status"
}

track_disable() {
  local scope settings rc=0
  scope="$(tel_config_get scope || true)"; [ -n "$scope" ] || scope="user"
  settings="$(tel_config_get settings_path || true)"; [ -n "$settings" ] || settings="$(tel_settings_path "$scope")"

  tel_merge disable "$settings" || rc=$?
  if [ "$rc" -ne 0 ]; then
    warn "could not cleanly unregister from $(tilde "$settings") (code $rc) — remove khub's entries by hand if needed"
  fi
  rm -f "$(tel_hook_file)" 2>/dev/null || true
  rm -f "$(tel_config_file)" 2>/dev/null || true
  rm -f "$(tel_task_file)" 2>/dev/null || true
  rm -f "${settings}.khub-lock" 2>/dev/null || true   # persistent flock sibling
  ok "telemetry disabled — hook unregistered and removed"
  detail "settings.json backups are kept for safety (a later 'khub track purge' will remove them + the local store)"
}

track_status() {
  local cfg; cfg="$(tel_config_file)"
  title "khub track — telemetry status"
  if [ ! -f "$cfg" ]; then
    info "telemetry is OFF (not enabled)"
    hint "enable with:  khub track enable"
    return 0
  fi

  local enabled scope settings py hook sha_recorded
  enabled="$(tel_config_get enabled || true)"
  scope="$(tel_config_get scope || true)"; [ -n "$scope" ] || scope="user"
  settings="$(tel_config_get settings_path || true)"; [ -n "$settings" ] || settings="$(tel_settings_path "$scope")"
  py="$(tel_config_get python3 || true)"; [ -n "$py" ] || py="$(tel_python3)"
  hook="$(tel_hook_file)"
  sha_recorded="$(tel_config_get hook_sha256 || true)"

  if [ "$enabled" = "1" ]; then ok "enabled (${scope} scope)"; else warn "config present but disabled"; fi
  detail "settings: $(tilde "$settings")"

  local st start end drift
  st="$(tel_merge status "$settings" --command "$(tel_hook_command "$py" "$hook")" 2>/dev/null || true)"
  start="$(printf '%s\n' "$st" | sed -n 's/^start=//p')"
  end="$(printf '%s\n' "$st" | sed -n 's/^end=//p')"
  drift="$(printf '%s\n' "$st" | sed -n 's/^drift=//p')"
  if [ "$start" = "present" ] && [ "$end" = "present" ]; then
    ok "hook registered (SessionStart + SessionEnd)"
  else
    bad "hook registration incomplete (start=${start:-?} end=${end:-?})"; hint "run 'khub track repair'"
  fi

  # hook-file integrity (F6): a tampered hook runs every session and is invisible to
  # a presence-only check — recompute the digest and compare to the one from enable.
  if [ -f "$hook" ]; then
    local sha_now; sha_now="$(sha256_of "$hook" 2>/dev/null || true)"
    if [ -n "$sha_recorded" ] && [ "$sha_now" = "$sha_recorded" ]; then
      ok "hook file integrity verified"
    elif [ -n "$sha_recorded" ]; then
      bad "hook file digest changed since enable (tampering or drift)"; hint "run 'khub track repair'"
    fi
  else
    bad "hook file missing: $(tilde "$hook")"; hint "run 'khub track repair'"
  fi

  case "$drift" in
    none) : ;;
    yes)  warn "hook command drift detected"; hint "run 'khub track repair'" ;;
    *)    warn "could not read hook registration state" ;;
  esac
}

track_repair() {
  local cfg; cfg="$(tel_config_file)"
  [ -f "$cfg" ] || die "telemetry is not enabled — nothing to repair" "run 'khub track enable'"
  local scope settings py
  scope="$(tel_config_get scope || true)"; [ -n "$scope" ] || scope="user"
  settings="$(tel_config_get settings_path || true)"; [ -n "$settings" ] || settings="$(tel_settings_path "$scope")"
  py="$(tel_python3)"; [ -n "$py" ] || die "python3 is required but was not found" "install python3, then re-run"

  # Rewrite the hook file (repairs a drifted/tampered/missing one) + refresh its sha,
  # then re-assert registration. Single-shot — never loops, so a reverting managed
  # settings.json cannot trigger a repair fight.
  local sha; sha="$(tel_install_hook)" || die "could not reinstall the telemetry hook"
  local cmd rc=0; cmd="$(tel_hook_command "$py" "$(tel_hook_file)")"
  tel_merge enable "$settings" --command "$cmd" || rc=$?
  [ "$rc" -eq 0 ] || die "could not re-register the telemetry hook (code $rc)" "run 'khub track status'"
  tel_write_config 1 "$sha" "$py" "$scope" "$settings"
  ok "telemetry repaired — hook reinstalled and re-registered"
}

# Set/clear/show the active ticket that sessions book their tokens to. Stored in
# its own file so enable/disable/repair (which rewrite telemetry.conf) never touch it.
track_task() {
  local tf; tf="$(tel_task_file)"
  if [ $# -eq 0 ]; then
    if [ -s "$tf" ]; then info "active task: $(head -1 "$tf" 2>/dev/null)"
    else info "active task: none (tokens attribute by git branch)"; hint "set one:  khub track task <ticket-id>"; fi
    return 0
  fi
  case "$1" in
    --clear|clear)
      rm -f "$tf" 2>/dev/null || true
      ok "active task cleared — tokens now attribute by git branch"
      return 0 ;;
  esac
  local id="$1"
  case "$id" in *[!A-Za-z0-9._/#-]*) die "invalid task id: $id" "allowed: letters, digits, and . _ / # -" ;; esac
  [ "${#id}" -le 64 ] || die "task id too long (max 64 chars)"
  mkdir -p "$(dirname "$tf")" 2>/dev/null || die "cannot create config dir"
  printf '%s\n' "$id" > "$tf" || die "cannot write the task file"
  chmod 600 "$tf" 2>/dev/null || true
  ok "active task set: $id"
  detail "sessions will book their tokens to '$id' until you change or clear it"
  hint "totals so far:  khub metrics --by-task"
}

cmd_track() {
  local sub="${1:-status}"; if [ $# -gt 0 ]; then shift; fi
  case "$sub" in
    enable)  track_enable  "$@" ;;
    disable) track_disable "$@" ;;
    status)  track_status  "$@" ;;
    repair)  track_repair  "$@" ;;
    task)    track_task    "$@" ;;
    *) die "unknown track subcommand: $sub" "try: khub track enable|disable|status|repair|task" ;;
  esac
}

# Show the most recent captured session's pre-rendered report (counts only — the
# report carries no raw prompt/response text). `--by-task` totals output tokens per
# ticket across ALL captured sessions instead.
cmd_metrics() {
  local by_task=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --by-task) by_task=1; shift ;;
      *) die "unknown option for metrics: $1" "try: khub metrics [--by-task]" ;;
    esac
  done
  if [ "$by_task" = "1" ]; then
    local mdir lib py; mdir="$(tel_state_dir)/metrics"
    if [ ! -d "$mdir" ]; then info "no telemetry captured yet"; hint "run 'khub track enable', then finish a session"; return 0; fi
    lib="$(khub_lib_dir)/telemetry/aggregate_tasks.py"
    [ -f "$lib" ] || die "telemetry helper not found: $(tilde "$lib")" "run from a full khub checkout or set KHUB_LIB_DIR"
    py="$(tel_python3)"; [ -n "$py" ] || die "python3 is required" "install python3"
    title "khub metrics — output tokens by task"
    "$py" "$lib" "$mdir"
    return 0
  fi
  local rdir; rdir="$(tel_state_dir)/report"
  if [ ! -d "$rdir" ]; then
    info "no telemetry captured yet"
    hint "run 'khub track enable', then finish a Claude Code session"
    return 0
  fi
  local f latest="" n=0
  for f in "$rdir"/*.txt; do
    [ -e "$f" ] || continue
    n=$((n+1))
    if [ -z "$latest" ] || [ "$f" -nt "$latest" ]; then latest="$f"; fi
  done
  if [ -z "$latest" ]; then
    info "no telemetry reports yet"
    hint "finish a Claude Code session with telemetry enabled"
    return 0
  fi
  title "khub metrics — latest session"
  cat "$latest"
  detail "report:  $(tilde "$latest")"
  detail "${n} session(s) captured in $(tilde "$rdir")"
}

usage() {
  cat <<EOF
khub ${KHUB_VERSION} — clone and update a delivered knowledge-hub snapshot

usage:
  khub init [dir]        clone the hub as a sibling under dir (default: current dir)
  khub update [--path D] [--dry-run] [--reset]
                         update your hub CONTENT clone to the latest snapshot
                         (--dry-run previews without changing anything;
                          --reset discards local changes, confirms first)
  khub upgrade [--check] update the khub CLI itself to the latest release
                         (--check only reports whether a newer release exists)
  khub doctor [--path D] [--report]
                         diagnose auth, access, sibling layout, and freshness
                         (--report appends a redacted, paste-ready diagnostic)
  khub version [--path D] print the CLI version and the clone's latest snapshot
  khub track <enable|disable|status|repair|task>
                         opt-in, LOCAL-ONLY session telemetry (OFF by default)
                         (enable [--project] registers a hook in settings.json,
                          backing it up first; disable removes only khub's entries;
                          task <id> books sessions' tokens to a ticket, --clear resets)
  khub metrics [--by-task]
                         show the latest session's local report (counts only), or
                         --by-task to total output tokens per ticket across sessions
  khub help              this message

Note: 'update' refreshes the delivered hub content; 'upgrade' updates this tool.

The hub clone is pull-only. Your work lives in your own code repos, which point
back at ../${HUB_DIRNAME}. Access is granted by the owner; removal stops future
pulls but the history already on your machine remains.
EOF
}

# ---- dispatch ---------------------------------------------------------------
main() {
  local cmd="${1:-help}"; if [ $# -gt 0 ]; then shift; fi
  case "$cmd" in
    init)            cmd_init "$@" ;;
    update)          cmd_update "$@" ;;
    upgrade|self-update) cmd_upgrade "$@" ;;
    doctor)          cmd_doctor "$@" ;;
    track)           cmd_track "$@" ;;
    metrics)         cmd_metrics "$@" ;;
    version|--version|-v) cmd_version "$@" ;;
    help|--help|-h)  usage ;;
    *)               printf 'unknown command: %s\n\n' "$cmd" >&2; usage >&2; exit 2 ;;
  esac
}
main "$@"
